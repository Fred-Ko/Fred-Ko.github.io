{
  "name": "@fredko/blog-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply fredko-blog --local",
    "db:migrate:remote": "wrangler d1 migrations apply fredko-blog --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260721.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0",
    "wrangler": "4.112.0"
  }
}
